-- ============================================================
-- Find queries (jobs) that reference any passed VIEW, by parsing the
-- query TEXT in INFORMATION_SCHEMA.JOBS.  (referenced_tables is unusable
-- here -- it expands views to base tables, so view names never appear.)
--
-- HARDENED after edge-case review (all verified against RE2):
--   * String literals stripped BEFORE comments  -> a view name inside a
--     string ('...'), SQL-as-a-string, or triple-quoted block does NOT match,
--     and a -- / # inside a string can't eat a real reference.
--   * Extraction gated to real table positions (FROM / JOIN / USING / comma)
--     -> struct field access (t.ds.col) and stray dotted tokens don't match.
--   * Comments (-- , # , /* multi-line */), backticks, cross-line/odd spacing,
--     case-sensitive identifiers, word boundaries, and partial-ref project
--     resolution (via the job's project_id) all handled as before.
--
-- Project resolution: a partial ref (dataset.view) is resolved against the
-- job's `project_id`. It matches a passed view only if project+dataset+view
-- all equal after resolution.
--
-- Output (one row per matching job):
--   query, job_id, project_id, creation_time,
--   referenced_objects (all tables/views in the query text, incl. views),
--   matched_views      (passed views found in this query).
-- ============================================================

DECLARE ALLOW_COMMA_PARTIAL BOOL DEFAULT TRUE;   -- FALSE if all your joins are explicit
DECLARE PARTIAL_PREFIX STRING DEFAULT CONCAT(
  r'(?:(?:^|[^A-Za-z0-9_])(?i:from|join|using)\s+',
  IF(ALLOW_COMMA_PARTIAL, r'|,\s*', ''), r')');

-- 1) Passed view names (always project_id.dataset_id.view_name).
CREATE TEMP TABLE targets AS
SELECT full_name FROM UNNEST([
  'gcp_project1.dataset_id.view_name'
  -- , ... 100+ of them
]) AS full_name;

-- 2) Read JOBS; clean the query text. ORDER MATTERS: strings before comments.
WITH src AS (
  SELECT
    job_id, project_id, creation_time, query,
    REGEXP_REPLACE(REGEXP_REPLACE(REGEXP_REPLACE(REGEXP_REPLACE(REGEXP_REPLACE(
    REGEXP_REPLACE(REGEXP_REPLACE(REGEXP_REPLACE(REGEXP_REPLACE(REGEXP_REPLACE(
      COALESCE(query,''),
      r"'''[\s\S]*?'''", ' '),          -- triple single-quoted strings
      r'"""[\s\S]*?"""', ' '),          -- triple double-quoted strings
      r"'(?:\\.|[^'\\\n])*'", ' '),     -- single-quoted strings (no newline)
      r'"(?:\\.|[^"\\\n])*"', ' '),     -- double-quoted strings (no newline)
      r'/\*[\s\S]*?\*/', ' '),          -- block comments
      r'(?:--|#)[^\n]*', ' '),          -- line comments (-- and #)
      '`', ' '),                        -- backticks
      r'\s*\.\s*', '.'),                -- whitespace around dots
      r'\s+', ' '),                     -- collapse whitespace
      r'\s+', ' ') AS q_norm
  FROM `region-us`.INFORMATION_SCHEMA.JOBS          -- <<< set region; UNION ALL more regions/projects
  WHERE job_type = 'QUERY'
    AND state = 'DONE'
    AND error_result IS NULL
    AND statement_type != 'SCRIPT'
    AND query IS NOT NULL
    AND creation_time >= TIMESTAMP_SUB(CURRENT_TIMESTAMP(), INTERVAL 90 DAY)  -- <<< tune window
),

-- 3) Extract references (only in table positions) and resolve to project.dataset.name.
resolved AS (
  SELECT
    s.job_id, s.project_id, s.creation_time, s.query,
    ARRAY(
      SELECT DISTINCT
        CASE WHEN ARRAY_LENGTH(SPLIT(r,'.')) = 3 THEN r
             ELSE CONCAT(s.project_id, '.', r) END
      FROM UNNEST(REGEXP_EXTRACT_ALL(
             s.q_norm,
             CONCAT(PARTIAL_PREFIX, r'([A-Za-z0-9_\-]+(?:\.[A-Za-z0-9_]+){1,2})'))) AS r
    ) AS referenced_objects
  FROM src s
)

-- 4) Keep jobs referencing >= 1 passed view; show which.
SELECT
  r.query,
  r.job_id,
  r.project_id,
  r.creation_time,
  r.referenced_objects,
  ARRAY(
    SELECT o FROM UNNEST(r.referenced_objects) AS o
    WHERE o IN (SELECT full_name FROM targets)
  ) AS matched_views
FROM resolved r
WHERE EXISTS (
  SELECT 1 FROM UNNEST(r.referenced_objects) AS o
  WHERE o IN (SELECT full_name FROM targets)
)
ORDER BY r.creation_time DESC;
